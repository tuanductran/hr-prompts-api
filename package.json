{
  "name": "hr-prompts-api",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "test": "bun test",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check --write",
    "ci": "biome ci",
    "spell": "cspell lint --no-progress \"**/*.md\" \"src/**/*.ts\" \"tests/**/*.ts\"",
    "mdlint": "markdownlint \"**/*.md\" --ignore node_modules",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "^1.3.9",
    "cspell": "^9.7.0",
    "drizzle-kit": "^0.31.9",
    "markdownlint-cli": "^0.48.0",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.3",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/server-timing": "^1.4.0",
    "@libsql/client": "^0.17.0",
    "@notionhq/client": "^5.11.0",
    "@sinclair/typebox": "^0.34.48",
    "@upstash/redis": "^1.36.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.26",
    "elysia-rate-limit": "^4.5.0",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}
