NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_PAGE_ID=43c2803e380041b5a577de5aff91d2bf

# Optional: Turso database (falls back to file:./local.db when not set)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# Optional: protect all endpoints with Bearer token auth
# Use the same value in ChatGPT Custom GPT → Actions → Authentication → Bearer token
API_KEY=

# Optional: HMAC-SHA256 secret for Notion webhook signature verification
NOTION_WEBHOOK_SECRET=

PORT=3000
CACHE_TTL_SECONDS=300

# Optional: comma-separated list of allowed CORS origins
# Default: https://chat.openai.com,https://chatgpt.com
CORS_ORIGINS=

# Optional: rate limiting (default: 60 requests per 60000 ms)
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# Optional: Upstash Redis (replaces in-memory cache — recommended for Vercel)
# Create a database at https://console.upstash.com and paste the REST credentials below.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: custom domain (used for documentation/links)
DOMAIN=

# Optional: GitHub repository (used for documentation/links)
GITHUB_REPO=

# Optional: log level (default: info; options: trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
